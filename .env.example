# =============================================
# 栖缘社环境变量配置示例
# 复制此文件为 .env 并修改对应值
# =============================================

# ============ 数据库配置 ============
# MySQL root 密码
MYSQL_ROOT_PASSWORD=lingtong_root_2024_secure

# MySQL 数据库名
MYSQL_DATABASE=lingtong_match

# MySQL 用户名
MYSQL_USER=lingtong

# MySQL 密码
MYSQL_PASSWORD=lingtong_pass_2024_secure

# 是否同步数据库结构（生产环境建议设为 false）
DB_SYNC=false

# ============ Redis 配置 ============
# Redis 密码
REDIS_PASSWORD=lingtong_redis_2024_secure

# ============ JWT 配置 ============
# JWT 密钥（务必修改为随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# JWT 过期时间
JWT_EXPIRES_IN=7d

# ============ Admin JWT 配置 ============
# 管理员 JWT 密钥（务必与普通用户 JWT 密钥不同）
ADMIN_JWT_SECRET=admin-jwt-secret-key-change-this
ADMIN_JWT_EXPIRES_IN=24h

# ============ 微信小程序配置 ============
# 微信小程序 AppID
WECHAT_APPID=your-wechat-appid

# 微信小程序 AppSecret
WECHAT_SECRET=your-wechat-appsecret

# ============ 微信支付配置 ============
# 微信支付商户号
WECHAT_MCH_ID=your-mch-id

# 微信支付 API v3 密钥
WECHAT_API_V3_KEY=your-api-v3-key

# 微信支付证书路径（容器内路径）
WECHAT_CERT_PATH=/app/certs/apiclient_cert.pem
WECHAT_KEY_PATH=/app/certs/apiclient_key.pem

# ============ 腾讯云配置 ============
# 腾讯云 SecretId
TENCENT_SECRET_ID=your-tencent-secret-id

# 腾讯云 SecretKey
TENCENT_SECRET_KEY=your-tencent-secret-key

# ============ 服务器配置 ============
# 服务器域名
DOMAIN=yourdomain.com

# CORS 允许的前端域名（生产环境必须配置，多个用逗号分隔）
CORS_ORIGINS=https://yourdomain.com

# API 基础路径（需与 CDN / OSS 协作：上传文件返回 URL 的基础前缀）
API_BASE_URL=https://yourdomain.com

# 管理后台基础路径
ADMIN_BASE_URL=https://yourdomain.com

# ============ 对象存储 OSS 配置（阿里云/腾讯云/七牛等）============
# 上传策略：local = 存到服务器本地磁盘，oss = 上传到对象存储
UPLOAD_STRATEGY=local

# 静态资源对外访问基础 URL（上传图片返回给客户端的前缀）
# - 未接入 CDN 时：设为 https://yourdomain.com
# - 接入 CDN 后：  设为 CDN 域名，如 https://cdn.yourdomain.com
# - 接入 OSS 后： 可设为 OSS 绑定域名或 CDN 域名
STATIC_BASE_URL=https://yourdomain.com

# ---------- 阿里云 OSS ----------
# OSS 地域节点（外网访问）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS Bucket 名称
OSS_BUCKET=your-bucket-name
# OSS 访问密钥
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS 上传路径前缀（建议: uploads/）
OSS_UPLOAD_PREFIX=uploads/

# ---------- 腾讯云 COS（二选一，留空则不使用）----------
# COS_BUCKET=your-bucket-appid
# COS_REGION=ap-guangzhou
# COS_SECRET_ID=your-secret-id
# COS_SECRET_KEY=your-secret-key

# ---------- 七牛云 Kodo（二选一，留空则不使用）----------
# QINIU_ACCESS_KEY=your-ak
# QINIU_SECRET_KEY=your-sk
# QINIU_BUCKET=your-bucket
# QINIU_DOMAIN=https://your-domain.qiniu.com

# ============ CDN 加速配置 ============
# CDN 加速域名（上传文件对外提供的 URL 域名）
CDN_DOMAIN=https://cdn.yourdomain.com

# 是否启用 CDN（true 时 STATIC_BASE_URL 自动使用 CDN_DOMAIN）
CDN_ENABLED=false

# CDN 回源方式
# - origin:    CDN → Nginx(服务器源站)  ← /uploads/ 从服务器拉取
# - oss:       CDN → OSS Bucket        ← /uploads/ 从 OSS 拉取（推荐）
CDN_ORIGIN_TYPE=origin

# CDN 回源 HOST（源站域名，CDN 回源请求时携带的 Host 头）
CDN_ORIGIN_HOST=yourdomain.com

# CDN 缓存策略
# 静态图片缓存时长（秒）：7 天
CDN_IMAGE_CACHE_TTL=604800
# 管理后台静态资源缓存时长（秒）：1 天
CDN_STATIC_CACHE_TTL=86400

# ============ SSL 证书路径（用于 Nginx）============
# Let's Encrypt 注册邮箱
SSL_EMAIL=admin@yourdomain.com
SSL_CERT_PATH=./docker/nginx/ssl/fullchain.pem
SSL_KEY_PATH=./docker/nginx/ssl/privkey.pem

# ============ 备份配置 ============
# 备份保留天数
BACKUP_RETENTION_DAYS=30

# 备份存储路径
BACKUP_PATH=./backups

# 是否启用远程备份（到 OSS / COS）
ENABLE_REMOTE_BACKUP=false
# 远程备份沿用上方 OSS 配置（OSS_ACCESS_KEY_ID / OSS_ACCESS_KEY_SECRET / OSS_BUCKET）

# ============ 监控配置 ============
# 企业微信机器人 Webhook（用于发送告警）
WECHAT_WEBHOOK_URL=

# 飞书机器人 Webhook（用于发送告警）
FEISHU_WEBHOOK_URL=

# 钉钉机器人 Webhook
DINGTALK_WEBHOOK_URL=

# 告警阈值
DISK_USAGE_THRESHOLD=80
MEMORY_USAGE_THRESHOLD=85
API_RESPONSE_TIME_THRESHOLD=3000
