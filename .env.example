# =============================================
# 栖缘社 — Docker Compose 环境变量（根目录 .env）
# 本文件由 docker-compose.yml 读取，用于容器启动时的变量替换
# 复制此文件为 .env 并修改对应值后 docker compose up -d
# =============================================

# ============ 数据库配置（MySQL 8.0 容器） ============
# MySQL root 用户密码（容器首次启动时创建）
MYSQL_ROOT_PASSWORD=lingtong_root_2024_secure

# MySQL 自动创建的数据库名
MYSQL_DATABASE=lingtong_match

# MySQL 普通用户（应用连接使用，非 root）
MYSQL_USER=lingtong

# MySQL 普通用户密码（应用连接使用）
MYSQL_PASSWORD=lingtong_pass_2024_secure

# 应用启动时是否自动同步数据库表结构（生产环境必须设为 false，避免数据丢失）
DB_SYNC=false

# ============ Redis 配置（Redis 7 Alpine 容器） ============
# Redis 访问密码（应用连接使用）
REDIS_PASSWORD=lingtong_redis_2024_secure

# ============ JWT 配置（用户端） ============
# 用户端 JWT 签名密钥（至少 32 字符随机字符串，生产环境务必修改）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# 用户端 JWT 过期时间（格式：数字+单位，如 7d / 24h / 60m）
JWT_EXPIRES_IN=7d

# ============ Admin JWT 配置（管理后台，必须与用户端密钥不同） ============
# 管理后台 JWT 签名密钥（务必与 JWT_SECRET 不同，防止用户端 token 越权访问管理后台）
ADMIN_JWT_SECRET=admin-jwt-secret-key-change-this

# 管理后台 JWT 过期时间（建议比用户端短，提升安全性）
ADMIN_JWT_EXPIRES_IN=24h

# ============ 微信小程序配置 ============
# 微信小程序 AppID（从微信公众平台 → 开发管理获取）
WECHAT_APPID=your-wechat-appid

# 微信小程序 AppSecret（从微信公众平台 → 开发管理获取，务必保密）
WECHAT_SECRET=your-wechat-appsecret

# ============ 微信支付配置（微信商户平台） ============
# 微信支付商户号（从微信支付商户平台获取，为空则禁用支付功能）
WECHAT_MCH_ID=your-mch-id

# 微信支付 API v3 密钥（32 字符，在商户平台设置）
WECHAT_API_V3_KEY=your-api-v3-key

# 微信支付 API 证书（容器内路径，通过 volume 挂载进入容器）
WECHAT_CERT_PATH=/app/certs/apiclient_cert.pem
WECHAT_KEY_PATH=/app/certs/apiclient_key.pem

# ============ 服务器配置 ============
# 服务器域名（用于 Nginx SSL 证书、CORS 白名单等）
DOMAIN=yourdomain.com

# CORS 允许的前端域名（多个用英文逗号分隔，生产环境必须配置）
CORS_ORIGINS=https://yourdomain.com

# 后端 API 基础 URL（前端 Vue/uni-app 发起请求使用）
# 本地开发设 http://localhost:3000；生产设 https://yourdomain.com/api
API_BASE_URL=https://yourdomain.com

# 管理后台基础 URL（用于生成管理后台链接，如邮件中的链接）
ADMIN_BASE_URL=https://yourdomain.com

# ============ SSL 证书路径（用于 Nginx 自动配置 HTTPS） ============
# Let's Encrypt 注册邮箱（certbot 申请/续期证书使用）
SSL_EMAIL=admin@yourdomain.com

# SSL 证书文件路径（容器内，由 certbot 或手动挂载提供）
SSL_CERT_PATH=./docker/nginx/ssl/fullchain.pem
SSL_KEY_PATH=./docker/nginx/ssl/privkey.pem

# ============ 数据库备份配置（scripts/backup.sh 脚本使用） ============
# 备份文件保留天数（超过此天数的 .sql.gz 备份会被自动清理）
BACKUP_RETENTION_DAYS=30

# 备份文件存储路径（相对于项目根目录）
BACKUP_PATH=./backups

# 是否启用远程备份（将备份文件同步到 OSS/COS，需额外配置对象存储凭证）
ENABLE_REMOTE_BACKUP=false

# ============ 监控与告警配置 ============
# 企业微信机器人 Webhook URL（用于发送系统告警通知，留空则不发送）
WECHAT_WEBHOOK_URL=

# 飞书机器人 Webhook URL（留空则不发送）
FEISHU_WEBHOOK_URL=

# 钉钉机器人 Webhook URL（留空则不发送）
DINGTALK_WEBHOOK_URL=

# 磁盘使用率告警阈值（百分比，超过此值触发告警）
DISK_USAGE_THRESHOLD=80

# 内存使用率告警阈值（百分比，超过此值触发告警）
MEMORY_USAGE_THRESHOLD=85

# API 响应时间告警阈值（毫秒，超过此值触发告警）
API_RESPONSE_TIME_THRESHOLD=3000
