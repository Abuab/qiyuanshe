# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=lingtong
DB_PASSWORD=lingtong_pass_2024_secure
DB_DATABASE=lingtong_match

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=lingtong_redis_2024_secure
REDIS_DB=0

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d

# 静态资源对外 URL 前缀（上传文件返回路径）
# 本地开发留空即可；生产/CDN 设 https://cdn.yourdomain.com
STATIC_BASE_URL=

# 微信配置
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-appsecret
WECHAT_MCHID=your-mch-id
WECHAT_APIKEY=your-api-v3-key
WECHAT_NOTIFY_URL=https://yourdomain.com/api/payment/notify

# 腾讯云配置（内容审核）
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
