# =============================================
# 栖缘社 — NestJS 后端应用环境变量（backend/.env）
# 本文件由 NestJS ConfigModule 读取，优先级高于 docker-compose 注入的变量
# 含 COS 对象存储、AI 多 Provider、语音转录等配置
# =============================================

# ============ 应用配置 ============
# 运行环境（development / production）
NODE_ENV=development

# 服务监听端口（Docker 容器内统一使用 3000）
PORT=3000

# ============ 数据库配置（MySQL） ============
# MySQL 主机地址（Docker 网络内使用容器名 mysql）
DB_HOST=localhost

# MySQL 端口
DB_PORT=3306

# MySQL 用户名
DB_USERNAME=lingtong

# MySQL 密码
DB_PASSWORD=lingtong_pass_2024_secure

# MySQL 数据库名
DB_DATABASE=lingtong_match

# ============ Redis 配置 ============
# Redis 主机地址（Docker 网络内使用容器名 redis）
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码（生产环境务必设置）
REDIS_PASSWORD=lingtong_redis_2024_secure

# Redis 数据库编号（默认 0，多个应用可共用 Redis 用不同 DB 隔离）
REDIS_DB=0

# ============ JWT 配置（用户端） ============
# 用户端 JWT 签名密钥（至少 32 字符）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# 用户端 JWT 过期时间（格式：数字+单位，如 7d / 24h / 60m / 30s）
JWT_EXPIRES_IN=7d

# ============ Admin JWT 配置（管理后台，必须与普通用户 JWT 密钥不同）============
# 管理后台 JWT 签名密钥（必须与 JWT_SECRET 不同）
ADMIN_JWT_SECRET=admin-jwt-secret-key-change-this

# 管理后台 JWT 过期时间
ADMIN_JWT_EXPIRES_IN=24h

# ============ MFA 临时令牌 ============
# MFA 两步验证临时令牌签名密钥（用于含 MFA 步骤的登录流程中间态）
JWT_MFA_SECRET=mfa-temp-token-secret-change-this

# ============ 数据库同步开关 ============
# 是否在应用启动时自动同步 TypeORM 实体 → 数据库表结构
# ⚠️ 生产环境必须设为 false，否则可能因 schema 变更导致数据丢失
DB_SYNC=false

# ============ CORS 配置 ============
# 允许跨域的前端域名（多个用英文逗号分隔，如 https://app.example.com,https://admin.example.com）
# 本地开发留空则自动放行所有来源
CORS_ORIGINS=

# ============ 静态资源 URL 配置 ============
# 静态资源对外访问的 URL 前缀（用于构建上传文件返回给前端的完整 URL）
# - 本地开发：留空，代码自动使用 API_BASE_URL 拼接
# - 生产环境：留空，COS 网关 /api/cos/image 会接管图片访问
# - 如使用 CDN：设为 CDN 域名（如 https://cdn.yourdomain.com）
STATIC_BASE_URL=

# ============ 微信小程序配置 ============
# 微信小程序 AppID
WECHAT_APPID=your-wechat-appid

# 微信小程序 AppSecret
WECHAT_SECRET=your-wechat-appsecret

# 微信支付商户号（留空则禁用支付功能）
WECHAT_MCHID=your-mch-id

# 微信支付 API 密钥
WECHAT_APIKEY=your-api-v3-key

# 微信支付回调通知 URL（必须为公网可访问的 HTTPS 地址）
WECHAT_NOTIFY_URL=https://yourdomain.com/api/payment/notify

# ============ 腾讯云配置（内容安全审核，如文本/图片检测）============
# 腾讯云 SecretId（用于调用腾讯云 API，如内容审核、短信等；留空则跳过审核）
TENCENT_SECRET_ID=your-tencent-secret-id

# 腾讯云 SecretKey
TENCENT_SECRET_KEY=your-tencent-secret-key

# ============ AI 多 Provider 配置 ============
# 支持同时配置 DeepSeek、Kimi、OpenAI、通义千问、文心一言等多个 AI 厂商
# 系统启动时会将配置加载到数据库，之后通过管理后台实时调整（无需重启）

# --- AI 全局配置 ---
# AES-256 加密密钥（用于加密存储数据库中的 API Key，必须 32 字符）
AI_ENCRYPT_KEY=your-32-byte-encryption-key-here!

# 默认 AI Provider（deepseek / kimi / openai / qwen）
AI_DEFAULT_PROVIDER=deepseek

# AI 请求超时时间（毫秒，防止个别厂商响应慢拖垮整个系统）
AI_REQUEST_TIMEOUT=30000

# 全局余额告警阈值（元，所有厂商总余额低于此值时触发告警通知）
AI_GLOBAL_BALANCE_ALERT_THRESHOLD=100

# --- DeepSeek 配置 ---
# 是否启用该 Provider
DEEPSEEK_ENABLED=true

# DeepSeek API Key（从 platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-deepseek-key

# DeepSeek API 地址
DEEPSEEK_API_BASE=https://api.deepseek.com

# 使用的模型名称
DEEPSEEK_MODEL_NAME=deepseek-chat

# 负载权重（所有启用的 Provider 权重之和应为 100，流量按权重比例分配）
DEEPSEEK_WEIGHT=60

# 故障优先级（数字越小越优先，主模型设 1，备用设 2+；主模型不可用时自动切换）
DEEPSEEK_PRIORITY=1

# 余额查询接口 URL（留空则跳过余额检查）
DEEPSEEK_BALANCE_URL=

# --- Kimi (Moonshot) 配置 ---
KIMI_ENABLED=true

# Kimi API Key（从 platform.moonshot.cn 获取）
KIMI_API_KEY=sk-your-kimi-key

# Kimi API 地址
KIMI_API_BASE=https://api.moonshot.cn

# 使用的模型名称
KIMI_MODEL_NAME=moonshot-v1-8k

# 负载权重（与 DeepSeek 权重合计 = 100）
KIMI_WEIGHT=40

# 故障优先级（备用模型，DeepSeek 不可用时启用）
KIMI_PRIORITY=2

# 余额查询接口 URL
KIMI_BALANCE_URL=

# --- 可扩展：OpenAI ---
# 如需接入，取消下方注释并填写 API Key
# OPENAI_ENABLED=false
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com
# OPENAI_MODEL_NAME=gpt-4o-mini
# OPENAI_WEIGHT=30
# OPENAI_PRIORITY=3
# OPENAI_BALANCE_URL=

# --- 可扩展：通义千问（阿里云）---
# 如需接入，取消下方注释并填写 API Key
# QWEN_ENABLED=false
# QWEN_API_KEY=sk-your-qwen-key
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode
# QWEN_MODEL_NAME=qwen-plus
# QWEN_WEIGHT=20
# QWEN_PRIORITY=4
# QWEN_BALANCE_URL=

# --- 可扩展：文心一言（百度）---
# 如需接入，取消下方注释并填写 API Key
# ERNIE_ENABLED=false
# ERNIE_API_KEY=your-ernie-key
# ERNIE_API_BASE=https://aip.baidubce.com/rpc/2.0/ai_custom/v1
# ERNIE_MODEL_NAME=ernie-4.0-8k
# ERNIE_WEIGHT=10
# ERNIE_PRIORITY=5
# ERNIE_BALANCE_URL=

# ============ 阿里云百炼 — 语音转录（Qwen3-ASR-Flash）============
# 用于将用户上传的语音消息转录为文本
# 是否启用语音转录
QWEN_ASR_ENABLED=true

# 阿里云百炼 API Key（从阿里云百炼控制台获取）
QWEN_ASR_API_KEY=sk-your-qwen-asr-key

# 语音转录 API 地址
QWEN_ASR_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 语音转录模型名称
QWEN_ASR_MODEL_NAME=qwen3-asr-flash

# 负载权重
QWEN_ASR_WEIGHT=10

# 故障优先级
QWEN_ASR_PRIORITY=5

# ============ 腾讯云 COS 对象存储配置 ============
# 总开关：true = 启用 COS（上传双写本地+COS，读取走签名 URL），false = 完全本地模式
COS_ENABLED=false

# 腾讯云 SecretId（从腾讯云 CAM 控制台 → 访问密钥 获取）
COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxxxx

# 腾讯云 SecretKey
COS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# COS 存储桶名称（格式：bucket-appid）
COS_BUCKET=qys-1319793487

# COS 存储桶所在地域
COS_REGION=ap-beijing

# COS 访问域名（用于生成签名 URL）
COS_DOMAIN=https://qys-1319793487.cos.ap-beijing.myqcloud.com

# COS 签名 URL 有效期（秒），默认 1800 = 30 分钟（用户浏览图片的窗口时间）
COS_SIGN_EXPIRES=1800

# ============ 本地资源路径配置 ============
# 服务器本地上传目录绝对路径
# - Docker 容器内路径：/app/uploads（通过 docker-compose 的 ./data/uploads:/app/uploads 挂载）
# - 本地开发：可设为相对路径 uploads 或留空（默认 backend/uploads/）
UPLOAD_DIR=/app/uploads

# 本地备份永久保留，不自动清理（设为 true 后系统不会执行任何定时清理逻辑）
LOCAL_BACKUP_RETAIN_FOREVER=true
