# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=qiyuanshe

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=qiyuanshe-jwt-secret-key-2024
JWT_EXPIRES_IN=7d

# 静态资源对外 URL 前缀（上传文件返回路径）
# 本地开发留空即可；生产/CDN 设 https://cdn.arvine.cn
STATIC_BASE_URL=

# 微信配置
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret
WECHAT_MCHID=your_mchid
WECHAT_APIKEY=your_apikey
WECHAT_NOTIFY_URL=https://date.arvine.cn/api/payment/notify
