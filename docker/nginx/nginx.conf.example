# 栖缘社 Nginx 反向代理配置（生产环境）
# 域名: yourdomain.com

user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

events {
    worker_connections 1024;
    use epoll;
    multi_accept on;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for" '
                    '$request_time $upstream_response_time';

    access_log /var/log/nginx/access.log main;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;
    client_max_body_size 50m;

    # Gzip 压缩
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml application/json application/javascript application/rss+xml application/atom+xml image/svg+xml;
    gzip_min_length 1000;

    # ============ COS 图片接口限流 ============
    # 对 /api/cos/image 接口限流，每个 IP 每秒最多 20 个请求，突发 30 个
    limit_req_zone $binary_remote_addr zone=cos_img:10m rate=20r/s;

    # 上游服务器定义
    upstream api_upstream {
        server api:3000;
        keepalive 32;
    }

    upstream admin_upstream {
        server admin:80;
        keepalive 16;
    }

    # ==================== HTTP (80) ====================
    # 仅用于：1) 重定向到 HTTPS  2) Let's Encrypt 验证
    server {
        listen 80;
        server_name yourdomain.com;

        # Let's Encrypt ACME 验证目录
        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
            default_type text/plain;
            allow all;
        }

        # 微信小程序业务域名校验文件（将下方内容替换为微信提供的校验码，逐字节一致、无换行）
        location = /V37v8qfP9n.txt {
            default_type text/plain;
            add_header Cache-Control "no-cache" always;
            return 200 "8b8202fc0267d399ba8cd6b52473dd79";
        }

        # 其余请求重定向到 HTTPS
        location / {
            return 301 https://$host$request_uri;
        }
    }

    # ==================== HTTPS (443) ====================
    server {
        listen 443 ssl http2;
        server_name yourdomain.com;

        # SSL 证书配置
        ssl_certificate /etc/nginx/ssl/fullchain.pem;
        ssl_certificate_key /etc/nginx/ssl/privkey.pem;

        # SSL 安全配置
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
        ssl_prefer_server_ciphers on;
        ssl_session_cache shared:SSL:10m;
        ssl_session_timeout 10m;
        ssl_session_tickets off;

        # HSTS（强制 HTTPS，有效期1年）
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

        # 安全头
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-XSS-Protection "1; mode=block" always;

        # Let's Encrypt ACME 验证目录（renew 时使用 webroot 模式）
        location /.well-known/acme-challenge/ {
            root /var/www/certbot;
            default_type text/plain;
            allow all;
        }

        # 微信小程序业务域名校验文件（将下方内容替换为微信提供的校验码，逐字节一致、无换行）
        location = /V37v8qfP9n.txt {
            default_type text/plain;
            add_header Cache-Control "no-cache" always;
            return 200 "8b8202fc0267d399ba8cd6b52473dd79";
        }

        # ============ API 代理（CDN 不应缓存 API 响应）============
        location /api/ {
            proxy_pass http://api_upstream/api/;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Connection "";

            # CDN 回源：标识真实客户端 IP
            proxy_set_header X-Origin-IP $remote_addr;

            # 禁止 CDN / 中间节点缓存 API 响应
            add_header Cache-Control "no-cache, no-store, must-revalidate" always;
            add_header Pragma "no-cache" always;
            expires -1;

            proxy_connect_timeout 60s;
            proxy_send_timeout 60s;
            proxy_read_timeout 60s;
        }

        # ============ COS 图片读取接口（带限流，确保 302 响应透传）============
        location /api/cos/image {
            # 限流：超过 burst 限制返回 503
            limit_req zone=cos_img burst=30 nodelay;
            limit_req_status 503;

            proxy_pass http://api_upstream/api/cos/image;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Connection "";

            # 确保 302 重定向响应透传，不拦截
            proxy_redirect off;
            proxy_intercept_errors off;

            # 不缓存 302 响应
            add_header Cache-Control "no-cache" always;
            expires -1;

            proxy_connect_timeout 60s;
            proxy_send_timeout 60s;
            proxy_read_timeout 60s;
        }

        # ============ 上传文件（CDN 源站回源入口）============
        location ^~ /uploads/ {
            proxy_pass http://api_upstream/uploads/;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            # 针对 CDN 回源的跨域头（允许 CDN 域名拉取）
            add_header Access-Control-Allow-Origin "*" always;

            # 超长缓存 — 图片文件名含时间戳，永不重复
            expires 365d;
            add_header Cache-Control "public, max-age=31536000, immutable";
        }

        # ============ WebSocket 实时通信代理 ============
        location /ws/chat {
            proxy_pass http://api_upstream/ws/chat;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_read_timeout 3600s;
            proxy_send_timeout 3600s;
        }

        # ============ 管理后台静态资源（带 hash 的可长缓存）============
        location ~* ^/assets/(.+\.(?:js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot))$ {
            proxy_pass http://admin_upstream;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            add_header Access-Control-Allow-Origin "*" always;
            # Vite 构建产物路径含 hash，可长期缓存
            expires 365d;
            add_header Cache-Control "public, max-age=31536000, immutable";
        }

        # ============ 管理后台（SPA 入口）============
        location / {
            proxy_pass http://admin_upstream;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }
}
